{
  "name": "inkos",
  "version": "0.4.3",
  "private": true,
  "description": "Multi-agent novel production system",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Narcooo/inkos"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "dev:hidden:stack": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\dev\\start-hidden-stack.ps1",
    "dev:hidden:server": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\dev\\start-hidden-server.ps1",
    "dev:hidden:web": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\dev\\start-hidden-web.ps1",
    "dev:hidden:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\dev\\stop-hidden-stack.ps1",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "release": "pnpm build && pnpm test && pnpm -r --filter './packages/*' publish --no-git-checks"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  }
}
